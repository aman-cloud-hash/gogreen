{
  "name": "gogreen-backend",
  "version": "1.0.0",
  "description": "Backend for Go Green Eco Tech Admin Panel",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "sync": "browser-sync start --proxy 'localhost:3000' --files '../frontend/**/*' --no-notify",
    "dev:all": "concurrently \"npm run dev\" \"npm run sync\""
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "browser-sync": "^3.0.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
